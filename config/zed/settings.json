// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // macOS native window tabs. Zed only *allows* tabbing here; whether new
  // windows actually merge into tabs is decided by macOS. With the system
  // "Prefer tabs when opening documents" pref at its default ("In Full Screen
  // Only"), tabs only appear when Zed is full screen. Set that pref to "Always"
  // (System Settings > Desktop & Dock) for tabs outside full screen.
  "use_system_window_tabs": true,
  "use_system_path_prompts": true,
  "cli_default_open_behavior": "new_window",
  "base_keymap": "VSCode",
  "terminal": {
    "font_family": "JetBrains Mono",
    "font_size": 14.0,
  },
  "ui_font_family": "JetBrains Mono",
  "buffer_font_family": "JetBrains Mono",
  "ui_font_size": 16,
  "buffer_font_size": 14,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Lumina Dark",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": true,
  },
}
